{
  "name": "Python AI Free Project",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.tabSize": 4,
        "files.autoSave": "afterDelay"
      }
    }
  },
  "postCreateCommand": "python --version",
  "openFiles": [
    "README.md",
    "main.py",
    "project_plan.md"
  ]
}